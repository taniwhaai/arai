{
  "hooks": {
    "CwdChanged": [
      {
        "hooks": [
          {
            "command": "arai guardrails --match-stdin",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "command": "arai guardrails --match-stdin",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "CLAUDE.md|.cursorrules|.windsurfrules|copilot-instructions.md"
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "command": "arai guardrails --match-stdin",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "command": "arai guardrails --match-stdin",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "command": "arai guardrails --match-stdin",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "arai guardrails --match-stdin",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "arai guardrails --match-stdin",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "arai guardrails --match-stdin",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}